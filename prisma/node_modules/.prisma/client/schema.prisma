// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  STUDENT
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ListingStatus {
  ACTIVE
  SOLD
  DELETED
}

enum NotificationType {
  TEAM_INVITE
  CONNECTION_REQUEST
  EVENT
  MARKETPLACE
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ==================== MODELS ====================

/// College — each campus identified by email domain
model College {
  id        String               @id @default(uuid())
  name      String
  domain    String               @unique
  users     User[]
  events    Event[]
  teams     Team[]
  listings  MarketplaceListing[]
  createdAt DateTime             @default(now())

  @@map("colleges")
}

/// User — student or admin belonging to a college
model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  name                String
  role                Role                 @default(STUDENT)
  collegeId           String
  college             College              @relation(fields: [collegeId], references: [id])
  resumeUrl           String?
  banned              Boolean              @default(false)
  skills              Skill[]
  teams               TeamMember[]
  messages            Message[]
  notifications       Notification[]
  listings            MarketplaceListing[]
  sentConnections     Connection[]         @relation("ConnectionSender")
  receivedConnections Connection[]         @relation("ConnectionReceiver")
  eventRegistrations  EventRegistration[]
  createdAt           DateTime             @default(now())

  @@index([collegeId])
  @@index([email])
  @@map("users")
}

/// Skill — extracted from resume or manually added
model Skill {
  id     String @id @default(uuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
  @@map("skills")
}

/// Connection — peer connections between students
model Connection {
  id         String           @id @default(uuid())
  senderId   String
  sender     User             @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User             @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@map("connections")
}

/// Team — project or hackathon team
model Team {
  id          String       @id @default(uuid())
  name        String
  description String?
  leaderId    String
  collegeId   String
  college     College      @relation(fields: [collegeId], references: [id])
  members     TeamMember[]
  messages    Message[]
  tasks       Task[]
  board       Board?
  createdAt   DateTime     @default(now())

  @@index([collegeId])
  @@map("teams")
}

/// TeamMember — junction table for team membership
model TeamMember {
  userId   String
  teamId   String
  role     String?
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@id([userId, teamId])
  @@map("team_members")
}

/// Event — campus events created by admins
model Event {
  id            String              @id @default(uuid())
  title         String
  description   String
  date          DateTime
  location      String
  bannerUrl     String?
  collegeId     String
  college       College             @relation(fields: [collegeId], references: [id])
  createdBy     String
  registrations EventRegistration[]
  createdAt     DateTime            @default(now())

  @@index([collegeId])
  @@map("events")
}

/// EventRegistration — tracks event sign-ups
model EventRegistration {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registeredAt DateTime @default(now())

  @@unique([userId, eventId])
  @@map("event_registrations")
}

/// Message — team chat messages
model Message {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([teamId])
  @@map("messages")
}

/// Task — team task board items (Kanban)
model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  assigneeId  String?
  teamId      String
  team        Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([teamId])
  @@map("tasks")
}

/// Board — whiteboard state (Excalidraw JSON)
model Board {
  id        String   @id @default(uuid())
  teamId    String   @unique
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  state     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("boards")
}

/// MarketplaceListing — campus marketplace items
model MarketplaceListing {
  id          String        @id @default(uuid())
  title       String
  description String
  price       Float
  images      String[]
  sellerId    String
  seller      User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  collegeId   String
  college     College       @relation(fields: [collegeId], references: [id])
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  @@index([collegeId])
  @@index([sellerId])
  @@map("marketplace_listings")
}

/// Notification — user notifications
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@map("notifications")
}
